{% extends "_layout.njk" %}

{% block content %}
<section class="section-shell">
    {% import "_macro/archive.njk" as archive with context %}
    {% import "_macro/ui.njk" as ui %}

    {% set posts = page.posts.sort('date', -1) %}

    {% if posts.length > 0 %}
        {{ archive.render_list(posts) }}
    {% else %}
        {% include "_partial/common/empty.njk" %}
    {% endif %}

    {% include "_partial/common/pagination.njk" %}
</section>
{% endblock %}
